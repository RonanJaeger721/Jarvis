rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isRonan() {
      return isSignedIn() && (
        request.auth.token.email == 'ronannyaks92@gmail.com' ||
        request.auth.uid == 'noDWZI62AUd4N5ChdfNg1AV1iM83'
      );
    }

    function isSectorOwner(data) {
      return isSignedIn() && (
        data.ownerId == request.auth.uid ||
        data.ownerId in ['ronan_sector', 'mikey_sector', 'guest_sector_01'] ||
        isRonan()
      );
    }

    // Contacts Collection
    match /contacts/{contactId} {
      allow list: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.ownerId in ['ronan_sector', 'mikey_sector', 'guest_sector_01'] ||
        isRonan()
      );
      allow get: if isSectorOwner(resource.data);
      allow create: if isSignedIn() && (
        request.resource.data.ownerId == request.auth.uid ||
        request.resource.data.ownerId in ['ronan_sector', 'mikey_sector', 'guest_sector_01'] ||
        isRonan()
      );
      allow update: if isSignedIn() && (
        (resource.data.ownerId == request.auth.uid || resource.data.ownerId in ['ronan_sector', 'mikey_sector', 'guest_sector_01'] || isRonan()) &&
        request.resource.data.ownerId == resource.data.ownerId
      );
      allow delete: if isSectorOwner(resource.data);
    }

    // Templates Collection
    match /templates/{templateId} {
      allow list: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.ownerId in ['ronan_sector', 'mikey_sector', 'guest_sector_01'] ||
        isRonan()
      );
      allow get: if isSectorOwner(resource.data);
      allow create: if isSignedIn() && (
        request.resource.data.ownerId == request.auth.uid ||
        request.resource.data.ownerId in ['ronan_sector', 'mikey_sector', 'guest_sector_01'] ||
        isRonan()
      );
      allow update: if isSignedIn() && (
        (resource.data.ownerId == request.auth.uid || resource.data.ownerId in ['ronan_sector', 'mikey_sector', 'guest_sector_01'] || isRonan()) &&
        request.resource.data.ownerId == resource.data.ownerId
      );
      allow delete: if isSectorOwner(resource.data);
    }

    // Logs Collection
    match /business_logs/{logId} {
      allow list: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.ownerId in ['ronan_sector', 'mikey_sector', 'guest_sector_01'] ||
        isRonan()
      );
      allow get: if isSectorOwner(resource.data);
      allow create: if isSignedIn() && (
        request.resource.data.ownerId == request.auth.uid ||
        request.resource.data.ownerId in ['ronan_sector', 'mikey_sector', 'guest_sector_01'] ||
        isRonan()
      );
      allow update: if isSignedIn() && (
        (resource.data.ownerId == request.auth.uid || resource.data.ownerId in ['ronan_sector', 'mikey_sector', 'guest_sector_01'] || isRonan()) &&
        request.resource.data.ownerId == resource.data.ownerId
      );
      allow delete: if isSectorOwner(resource.data);
    }

    // Habits Collection
    match /personal_habits/{habitId} {
      allow list: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.ownerId in ['ronan_sector', 'mikey_sector', 'guest_sector_01'] ||
        isRonan()
      );
      allow get: if isSectorOwner(resource.data);
      allow create: if isSignedIn(); 
      allow update: if isSectorOwner(resource.data);
      allow delete: if isSectorOwner(resource.data);
    }

    // Projects Collection
    match /project_tasks/{taskId} {
      allow list: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.ownerId in ['ronan_sector', 'mikey_sector', 'guest_sector_01'] ||
        isRonan()
      );
      allow get: if isSectorOwner(resource.data);
      allow create: if isSignedIn();
      allow update: if isSectorOwner(resource.data);
      allow delete: if isSectorOwner(resource.data);
    }

    // Goals Collection
    match /daily_goals/{goalId} {
      allow list: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.ownerId in ['ronan_sector', 'mikey_sector', 'guest_sector_01'] ||
        isRonan()
      );
      allow get: if isSectorOwner(resource.data);
      allow create: if isSignedIn();
      allow update: if isSectorOwner(resource.data);
      allow delete: if isSectorOwner(resource.data);
    }

    // Test Connection
    match /test/connection {
      allow read: if true;
    }
  }
}
