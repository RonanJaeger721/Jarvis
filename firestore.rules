rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }

    // Validation helpers
    function isValidContact(data) {
      // Identity Integrity
      return data.ownerId == request.auth.uid
        // Type Safety & Size Enforcements
        && data.businessName is string && data.businessName.size() <= 200
        && data.phoneNumber is string && data.phoneNumber.size() <= 20
        && data.status in ['New', 'Opened', 'Contacted', 'Replied', 'Follow Up', 'Closed', 'Not Interested']
        && (data.get('contactName', '') is string && data.get('contactName', '').size() <= 100)
        && (data.get('niche', '') is string && data.get('niche', '').size() <= 100)
        && (data.get('notes', '') is string && data.get('notes', '').size() <= 2000)
        && (data.get('draftedMessage', '') is string && data.get('draftedMessage', '').size() <= 10000)
        && data.createdAt is string
        && (data.get('followUpDate', '') is string)
        && (data.get('lastContactedAt', '') is string);
    }

    function isValidTemplate(data) {
      return data.ownerId == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && data.content is string && data.content.size() <= 5000
        && (data.get('niche', '') is string && data.get('niche', '').size() <= 100);
    }

    // 1. Mandatory Size Enforcements & Identity Guarding
    match /contacts/{contactId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isVerified() 
        && isValidContact(incoming())
        && incoming().keys().hasAll(['businessName', 'phoneNumber', 'status', 'ownerId', 'createdAt']);
        
      allow update: if isVerified()
        && isValidContact(incoming())
        && incoming().ownerId == existing().ownerId
        && (
          // Action: Status Update or Follow Up
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'followUpDate', 'lastContactedAt']) ||
          // Action: Quick Edits
          incoming().diff(existing()).affectedKeys().hasOnly(['draftedMessage', 'notes']) ||
          // Action: Full Edit
          incoming().diff(existing()).affectedKeys().hasOnly(['businessName', 'contactName', 'phoneNumber', 'niche', 'notes', 'status', 'draftedMessage', 'followUpDate', 'lastContactedAt'])
        );
        
      allow delete: if isVerified() && resource.data.ownerId == request.auth.uid;
    }

    match /templates/{templateId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isVerified() 
        && isValidTemplate(incoming())
        && incoming().keys().hasAll(['name', 'content', 'ownerId']);
        
      allow update: if isVerified()
        && isValidTemplate(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'content', 'niche']);
        
      allow delete: if isVerified() && resource.data.ownerId == request.auth.uid;
    }

    // Connection test rule
    match /test/connection {
      allow read: if true;
    }
  }
}
